  "records": {
    "description": "Crafts filtered items. Works with 2-9 slot crafts. Can be adapted to be 1 slot. 1 slot and hopper locked variations are in the thread.",
    "features": [
      "Compact",
      "Signal Strength Isolated"
    ],
    "considerations": [
      "Expensive",
      "AB tileable"
    ],
    "instructions": [
      "The lower filter hopper must be configured to output signal strength 1 when read from the comparator. This comparator subtracts from the comparator reading the top filter hopper to make the filter circuit smaller."
    ],
    "notes": "Includes hopperlocked and 1 Slot / Uncrafter clocked versions.",
    "compatibility": "1.21+"
  },
