  "records": {
    "description": "A clocked compactor designed for compacting items that use a 3x3 crafting pattern, such as slime blocks and redstone blocks.",
    "features": [
      "Includes SSI and SS3 versions.",
      "Can be used for 2-9 single item recipes as long as the only valid recipe is the 3x3 pattern.",
      "Thread includes box loader versions from 4x to 24x hopper speed.",
      "Additional designs: 2x2 compactors, bone to bone block compactors, and a 16x nugget to block compactor loader."
    ],
    "instructions": [
      {
        "title": "For SSI filter setup (SSX, where X is the number of dust, F is filter item, rest blockers):",
        "isOrdered": false,
        "items": [
          "SS2 Filter: F-16-1-1-1",
          "SS4 Filter: F-62-1-1-1"
        ]
      }
    ]
