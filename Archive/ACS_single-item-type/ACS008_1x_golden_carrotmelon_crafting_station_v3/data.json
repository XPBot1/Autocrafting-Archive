  "records": {
    "description": "Takes in boxes of gold blocks and boxes of carrots, and the crafter station outputs boxes of golden carrots.",
    "features": [
      "auto stops if it runs out of ingredients",
      "recycles empty boxes from the carrot unloader.",
      "spam proof input",
      "integrated box loader"
    ],
    "considerations": [
      "Multiple toggle states, make sure all lamps & rs blocks are in the correct state after building",
      "requires at least a stack of gold blocks and 20 stacks of carrots to start the crafter",
      "no overflow protection"
    ],
    "instructions": [
      "Build the device using the provided Litematic.",
      "Ensure all lamps and redstone blocks are in the correct state after building.",
      "Input boxes of gold blocks and carrots to start crafting.",
      "The device will automatically output boxes of golden carrots.",
      "Access empty gold block boxes from the barrel via the trapdoor at the top."
    ],
    "notes": "- Inspired by cubicmetere auto crafting shulker box video and \"scheduling the comparator technique\" design and signal watcher made by geg2055\n- Waterless variant for the nether included",
    "compatibility": "1.21+"
  },
