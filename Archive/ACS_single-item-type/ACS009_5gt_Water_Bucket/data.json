  "records": {
    "description": "Converts Iron Blocks to Water Buckets on a 5gt Clock, using Fluid Tick Manipulation to ensure the water regenerates at the correct timing even when first turned on.",
    "features": [
      "Extremely compact",
      "Outputs 14400 Water Buckets/hr, uses 4800 Iron Blocks/hr."
    ],
    "notes": "External overflow protection is required, otherwise when storage fills up, buckets will accumulate in the dispenser, leading to empty buckets in output.",
    "instructions": [
      "When building, to get the Hopper Minecart clipped inside the Observer, align Hopper Minecart against Fence first using a rail, then break the rail and simply push observer in from above.",
      "How to use: Load up chest with Iron Blocks, then turn on lever."
    ],
    "compatibility": "1.21+"
  },
