  "records": {
    "description": "A 16gt empty shulker box crafter that processes input boxes of logs and shulker shells. Includes a colored box crafter version.",
    "features": [
      "Crafts at 16 game ticks per cycle.",
      "1:1 consumption ratio of logs and shells.",
      "Design prevents breaking by maintaining an 8-log difference in raw materials.",
      "Observer under comparator extends crafting cycle from 15t to 16t."
    ],
    "notes": "DO NOT power the noteblock to shutdown; instead, lock or cut the output hopper.",
    "instructions": [
      "After building is complete, remove the two hoppers under the box, then place the material box.",
      "Take 8 logs from the box and craft them into 4 chests, then put them into the final crafter (box crafter).",
      "Place the hopper under the box, then put an item into the detected hopper and take it out to ready the device."
    ],
    "compatibility": "1.21+"
  },
